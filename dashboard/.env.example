# Copy to .env.local and fill in. Never commit .env.local.

# ----- Supabase -----
# From https://supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — used by Server Actions / route handlers
SUPABASE_SERVICE_ROLE_KEY=

# ----- Dev fixtures -----
# When set to 1 (and no SUPABASE_URL), the UI runs against in-memory mock data.
# Useful for iterating on the dashboard before provisioning Supabase.
NEXT_PUBLIC_USE_MOCK_DATA=1
