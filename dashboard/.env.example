# Copy to .env.local and fill in. Never commit .env.local.

# ----- Data source -----
# Which backend the dashboard reads from. One of: mock | file | supabase
# Auto-resolves to supabase when SUPABASE_URL+ANON_KEY are set, else mock.
NEXT_PUBLIC_DATA_SOURCE=mock

# When NEXT_PUBLIC_DATA_SOURCE=file, the dashboard reads the latest
# `runs/*.jsonl` from this directory. Default: ../backend/runs
# PIPELINE_OUTPUT_DIR=../backend/runs

# ----- Supabase -----
# From https://supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — used by Server Actions / route handlers
SUPABASE_SERVICE_ROLE_KEY=
