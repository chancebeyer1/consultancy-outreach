# Copy to .env and fill in. Never commit .env.

# ----- LLM -----
ANTHROPIC_API_KEY=sk-ant-...
# Sonnet for drafting (cheap, good), Opus for scoring/reply triage (slower, smarter)
CLAUDE_MODEL_DRAFT=claude-sonnet-4-6
CLAUDE_MODEL_REASON=claude-opus-4-7

# ----- Unipile (LinkedIn + email + profile enrichment, one unified API) -----
# Replaces Heyreach (LinkedIn send), Smartlead (email), and ProxyCurl (enrichment).
# Create accounts at https://www.unipile.com, then connect ONE LinkedIn account
# and ONE mailbox in the Unipile dashboard.
UNIPILE_API_KEY=
# Your tenant's data-source host, e.g. api8.unipile.com:13443 (no scheme).
UNIPILE_DSN=
# The account ids Unipile assigns once each account is connected.
UNIPILE_LINKEDIN_ACCOUNT_ID=
UNIPILE_EMAIL_ACCOUNT_ID=

# ----- Web search for company signals -----
TAVILY_API_KEY=
# Optional fallback / alternative
SERPER_API_KEY=

# ----- Bidding module (gov contracts + freelance opportunity sourcing) -----
# Discovers software / AI-agent work, fit-scores it, and drafts proposals into the /bids
# review queue. All keys optional and independent — an unset source is simply skipped, so
# you can go live with the free/no-approval sources immediately.
#
# SAM.gov (US federal contracts): free. Make an account at https://sam.gov, then Account
# Details -> generate a personal API key. FREE TIER IS ~10 REQUESTS/DAY (the sweep respects
# this by running at most once daily); register your LLC as an entity to get 1,000/day.
SAM_GOV_API_KEY=
# Upwork (highest-relevance source): GATED. Apply at https://www.upwork.com/developer — a
# ~2-week review. Once approved, do OAuth2 and paste a current access token here (refresh it
# out of band). Never scrape Upwork and never auto-submit proposals — instant-ban ToS.
UPWORK_ACCESS_TOKEN=
UPWORK_ORG_ID=
# Upwork via Apify (OPTIONAL STOPGAP until the official API above is approved): the actor
# neatrat/upwork-job-scraper SCRAPES upwork.com's public job search. This VIOLATES Upwork's ToS,
# so enable it deliberately and turn it OFF once UPWORK_ACCESS_TOKEN is live. DOUBLE-GATED + OFF
# by default — the source stays skipped unless BOTH the token AND the explicit enable flag are
# set. Discovery only; it never submits. Get a token at https://console.apify.com → Settings →
# Integrations → API tokens. APIFY_UPWORK_QUERY optionally overrides the default AI/agent search.
APIFY_TOKEN=
APIFY_UPWORK_ENABLED=
APIFY_UPWORK_QUERY=
# RemoteOK, Hacker News "who is hiring", and LinkedIn jobs need NO extra keys — RemoteOK/HN
# are free public feeds; LinkedIn rides your existing UNIPILE_* credentials above.
#
# --- Bidding automation (all OFF by default) ---
# AUTO-APPROVE: fit >= this (AND software AND eligible) → the drafted bid lands pre-approved in
# /bids "Ready to submit" instead of waiting in "Needs approval". 0 = every bid waits for you.
BIDS_AUTO_APPROVE_MIN_FIT=0
# FREELANCER AUTO-SUBMIT: '1' lets the daily job PLACE approved Freelancer bids with no click
# (Freelancer's API sanctions bid placement; Upwork/SAM never auto-submit). Guarded by a
# min-fit floor + a hard per-day cap because unattended bidding burns bid quota and can flag a
# new account. Leave OFF until you have reviews + a paid Freelancer plan.
FREELANCER_AUTO_SUBMIT=
FREELANCER_AUTO_SUBMIT_MIN_FIT=80
FREELANCER_AUTO_SUBMIT_DAILY_CAP=3
# Freelancer.com: self-serve, no review gate. Log in, then create an app at
# https://accounts.freelancer.com/settings/create_app and mint a token from the app page
# (read-only search needs only the `basic` scope). Paste it here + add to the Modal secret.
FREELANCER_OAUTH_TOKEN=
# Upwork job-alert EMAIL ingestion (ToS-safe — parses the alert emails Upwork sends YOU; no
# scraping). Point this at the connected Unipile mailbox that receives your Upwork alerts.
# Unset → uses the main UNIPILE_EMAIL_ACCOUNT_ID. To feed it: set a Gmail filter that
# auto-forwards Upwork job alerts to that mailbox, OR connect the alert Gmail to Unipile.
UPWORK_ALERT_EMAIL_ACCOUNT_ID=
# Optional: your deployed dashboard origin (e.g. https://your-dashboard.vercel.app). Used to
# build the clickable /bids link in the "new bid drafts" alert email.
DASHBOARD_URL=

# ----- X / Twitter viral-post discovery (optional) -----
# Powers the "react to a viral AI tweet" LinkedIn posts. Finds high-engagement AI
# tweets to react to (no official X API needed). Sign up at https://twitterapi.io,
# create a key, set it here AND in the Modal secret. If unset, that path is skipped.
XSEARCH_API_KEY=

# ----- Database (optional; leave BLANK for Phase-1 file mode) -----
# Set this ONLY when you have a real Postgres/Supabase DB. Any non-empty value makes
# the pipeline read campaigns from the DB — a bogus placeholder will crash it, so
# keep it empty until the database actually exists.
DATABASE_URL=
# Used by the dashboard's supabase data-source mode (writes campaigns/decisions).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ----- Outreach config -----
# Default landing page + Cal.com URLs. A campaign can override these per-persona
# (campaigns.landing_url / campaigns.calcom_url); these are the fallback.
LANDING_URL=https://your-domain.com
CALCOM_URL=https://cal.com/your-handle

# ----- Meta lead ads (INBOUND paid leads) -----
# Advantage+ runs the ads; we only ingest the leads its forms collect (meta_leads_webhook).
# META_VERIFY_TOKEN: any string you choose; enter the same value as the Webhook Verify Token
#   in the Meta app dashboard.
# META_APP_SECRET: your Meta app's App Secret (used to HMAC-verify webhook POSTs).
# META_PAGE_ACCESS_TOKEN: a long-lived Page access token with the `leads_retrieval` permission,
#   for the Page your lead form lives on (used to fetch each submitted lead's fields).
META_VERIFY_TOKEN=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=

# ----- Twilio (instant SMS to inbound leads) -----
# Optional: unset → inbound response falls back to email only.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ----- Error Agent (auto-fix PRs for recurring failures) -----
# Optional. Without a token the agent still root-causes every error and emails the digest with a
# ready-to-apply fix — it just can't open the PR. GITHUB_TOKEN = a fine-grained PAT scoped to the
# repo with Contents: read/write + Pull requests: read/write.
GITHUB_TOKEN=
GITHUB_REPO=chancebeyer1/consultancy-outreach
