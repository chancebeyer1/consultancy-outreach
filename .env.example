# Copy to .env and fill in. Never commit .env.

# ----- LLM -----
ANTHROPIC_API_KEY=sk-ant-...
# Sonnet for drafting (cheap, good), Opus for scoring/reply triage (slower, smarter)
CLAUDE_MODEL_DRAFT=claude-sonnet-4-6
CLAUDE_MODEL_REASON=claude-opus-4-7

# ----- LinkedIn enrichment -----
PROXYCURL_API_KEY=

# ----- Web search for company signals -----
TAVILY_API_KEY=
# Optional fallback / alternative
SERPER_API_KEY=

# ----- GitHub (optional, for technical signal) -----
GITHUB_TOKEN=

# ----- Phase 2+ : senders -----
HEYREACH_API_KEY=
# Fallback campaign id when no channel-specific override is set.
HEYREACH_CAMPAIGN_DEFAULT=
# Per-channel overrides — send_approvals.py picks the most specific match.
# Set up one Heyreach campaign per channel; template should reference the
# custom variable {{custom_body}} (and optionally {{custom_hook}}).
HEYREACH_CAMPAIGN_LINKEDIN_CONNECT=
HEYREACH_CAMPAIGN_LINKEDIN_DM=
HEYREACH_CAMPAIGN_LINKEDIN_FOLLOWUP_1=
HEYREACH_CAMPAIGN_LINKEDIN_FOLLOWUP_2=

SMARTLEAD_API_KEY=
SMARTLEAD_CAMPAIGN_DEFAULT=

# ----- Phase 2+ : database -----
DATABASE_URL=postgresql://user:pass@host:5432/outreach
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ----- Outreach config -----
# Your public landing page URL — gets dropped into messages where appropriate
LANDING_URL=https://your-domain.com
# Your Cal.com booking URL — used in positive-reply drafts
CALCOM_URL=https://cal.com/your-handle
