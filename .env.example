# Copy to .env and fill in. Never commit .env.

# ----- LLM -----
ANTHROPIC_API_KEY=sk-ant-...
# Sonnet for drafting (cheap, good), Opus for scoring/reply triage (slower, smarter)
CLAUDE_MODEL_DRAFT=claude-sonnet-4-6
CLAUDE_MODEL_REASON=claude-opus-4-7

# ----- LinkedIn enrichment -----
PROXYCURL_API_KEY=

# ----- Web search for company signals -----
TAVILY_API_KEY=
# Optional fallback / alternative
SERPER_API_KEY=

# ----- GitHub (optional, for technical signal) -----
GITHUB_TOKEN=

# ----- Phase 2+ : senders -----
HEYREACH_API_KEY=
HEYREACH_CAMPAIGN_DEFAULT=

SMARTLEAD_API_KEY=
SMARTLEAD_CAMPAIGN_DEFAULT=

# ----- Phase 2+ : database -----
DATABASE_URL=postgresql://user:pass@host:5432/outreach
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ----- Outreach config -----
# Your public landing page URL — gets dropped into messages where appropriate
LANDING_URL=https://your-domain.com
# Your Cal.com booking URL — used in positive-reply drafts
CALCOM_URL=https://cal.com/your-handle
